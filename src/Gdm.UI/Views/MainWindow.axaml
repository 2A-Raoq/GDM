<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Gdm.UI.Views.MainWindow"
        Width="960"
        Height="620"
        Title="GDM - Vault local">
  <Grid RowDefinitions="Auto,*" Margin="16">
    <TextBlock Text="Gestionnaire de mots de passe local"
               FontSize="22"
               FontWeight="Bold"
               Margin="0,0,0,12" />

    <Grid Grid.Row="1" ColumnDefinitions="2*,3*">
      <StackPanel>
        <TextBlock Text="Mot de passe maître" />
        <TextBox PasswordChar="*" Text="{Binding MasterPassword}" />
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
          <Button Content="Créer" Command="{Binding CreateCommand}" />
          <Button Content="Déverrouiller" Command="{Binding UnlockCommand}" />
          <Button Content="Verrouiller" Command="{Binding LockCommand}" />
        </StackPanel>

        <TextBlock Text="Recherche" Margin="0,8,0,0" />
        <TextBox Text="{Binding SearchQuery}" />
        <Button Content="Rechercher" Command="{Binding SearchCommand}" Margin="0,6,0,10" />

        <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <TextBlock Text="{Binding ServiceName}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Login}" Opacity="0.8" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>

      <StackPanel Grid.Column="1" Spacing="8" Margin="16,0,0,0">
        <TextBlock Text="Service" />
        <TextBox Text="{Binding EditServiceName}" />

        <TextBlock Text="Identifiant" />
        <TextBox Text="{Binding EditLogin}" />

        <TextBlock Text="Mot de passe" />
        <TextBox PasswordChar="*" Text="{Binding EditPassword}" />

        <TextBlock Text="Note" />
        <TextBox Text="{Binding EditNote}" AcceptsReturn="True" Height="100" />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Générer" Command="{Binding GeneratePasswordCommand}" />
          <Button Content="Ajouter" Command="{Binding AddCommand}" />
          <Button Content="Modifier" Command="{Binding UpdateCommand}" />
        </StackPanel>

        <TextBlock Text="{Binding Message}" Foreground="LightGreen" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>